{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default",
            "binaryDir": "${sourceDir}/build"
        },
        {
            "name": "authoring",
            "inherits": "default",
            "displayName": "Authoring Tool",
            "description": "Builds the graphical authoring tool alongside the default configuration",
            "cacheVariables": {
                "AME_BUILD_AUTHORING": "ON"
            }
        },
        {
            "name": "all-on",
            "displayName": "All Optional Dependencies Enabled",
            "binaryDir": "${sourceDir}/build-all-enabled",
            "cacheVariables": {
                "AME_FOXGLOVE": "ON",
                "AME_NEURO": "ON",
                "PYRAMID_ENABLE_FLATBUFFERS": "ON",
                "PYRAMID_ENABLE_GRPC": "ON",
                "PYRAMID_ENABLE_PROTOBUF": "ON",
                "PYRAMID_ENABLE_ROS2": "ON"
            }
        },
        {
            "name": "neuro-dev",
            "displayName": "AME + Neuro-Symbolic Infrastructure",
            "description": "Builds AME core and ame_neuro; no Foxglove or gRPC.",
            "binaryDir": "${sourceDir}/build-neuro",
            "cacheVariables": {
                "UNMANNED_BUILD_PYRAMID": "ON",
                "UNMANNED_BUILD_AME": "ON",
                "AME_NEURO": "ON",
                "AME_FOXGLOVE": "OFF",
                "PYRAMID_ENABLE_FLATBUFFERS": "OFF",
                "PYRAMID_ENABLE_GRPC": "OFF",
                "PYRAMID_ENABLE_PROTOBUF": "OFF",
                "PYRAMID_ENABLE_ROS2": "OFF"
            }
        },
        {
            "name": "all-off",
            "displayName": "All Optional Dependencies Disabled",
            "binaryDir": "${sourceDir}/build-all-off",
            "cacheVariables": {
                "AME_FOXGLOVE": "OFF",
                "PYRAMID_ENABLE_FLATBUFFERS": "OFF",
                "PYRAMID_ENABLE_GRPC": "OFF",
                "PYRAMID_ENABLE_PROTOBUF": "OFF",
                "PYRAMID_ENABLE_ROS2": "OFF"
            }
        },
        {
            "name": "flatbuffers-only",
            "displayName": "Only FlatBuffers Enabled",
            "binaryDir": "${sourceDir}/build-flatbuffers-only",
            "cacheVariables": {
                "AME_FOXGLOVE": "OFF",
                "PYRAMID_ENABLE_FLATBUFFERS": "ON",
                "PYRAMID_ENABLE_GRPC": "OFF",
                "PYRAMID_ENABLE_PROTOBUF": "OFF",
                "PYRAMID_ENABLE_ROS2": "OFF"
            }
        },
        {
            "name": "ame-devenv",
            "displayName": "AME DevEnv",
            "description": "Build AME core and Python bindings for the PCL DevEnv with only required PYRAMID JSON bindings enabled.",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "UNMANNED_BUILD_PYRAMID": "ON",
                "UNMANNED_BUILD_AME": "ON",
                "CMAKE_POSITION_INDEPENDENT_CODE": "ON",
                "AME_BUILD_PYTHON": "ON",
                "AME_FOXGLOVE": "OFF",
                "PYRAMID_ENABLE_FLATBUFFERS": "OFF",
                "PYRAMID_ENABLE_GRPC": "OFF",
                "PYRAMID_ENABLE_PROTOBUF": "OFF",
                "PYRAMID_ENABLE_ROS2": "OFF",
                "AME_BUILD_AUTHORING": "ON"                
            }
        }
    ],
    "buildPresets": [
        {
            "name": "release",
            "configurePreset": "default",
            "configuration": "Release"
        },
        {
            "name": "debug",
            "configurePreset": "default",
            "configuration": "Debug"
        },
        {
            "name": "all-on-release",
            "configurePreset": "all-on",
            "configuration": "Release"
        },
        {
            "name": "all-off-release",
            "configurePreset": "all-off",
            "configuration": "Release"
        },
        {
            "name": "all-off-debug",
            "configurePreset": "all-off",
            "configuration": "Debug"
        },
        {
            "name": "flatbuffers-only-release",
            "configurePreset": "flatbuffers-only",
            "configuration": "Release"
        },
        {
            "name": "flatbuffers-only-debug",
            "configurePreset": "flatbuffers-only",
            "configuration": "Debug"
        },
        {
            "name": "ame-devenv-release",
            "configurePreset": "ame-devenv",
            "configuration": "Release"
        },
        {
            "name": "ame-devenv-debug",
            "configurePreset": "ame-devenv",
            "configuration": "Debug"
        },
        {
            "name": "neuro-dev-release",
            "configurePreset": "neuro-dev",
            "configuration": "Release"
        },
        {
            "name": "neuro-dev-debug",
            "configurePreset": "neuro-dev",
            "configuration": "Debug"
        }
    ],
    "testPresets": [
        {
            "name": "all-on-release",
            "configurePreset": "all-on",
            "configuration": "Release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "all-off-release",
            "configurePreset": "all-off",
            "configuration": "Release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "all-off-debug",
            "configurePreset": "all-off",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "flatbuffers-only-release",
            "configurePreset": "flatbuffers-only",
            "configuration": "Release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "flatbuffers-only-debug",
            "configurePreset": "flatbuffers-only",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "ame-devenv-debug",
            "configurePreset": "ame-devenv",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "neuro-dev-debug",
            "configurePreset": "neuro-dev",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}

# ame_coreConfig.cmake — generated by configure_package_config_file
# Provides the ame::ame_core imported target for use by the ros2/ package.
@PACKAGE_INIT@

# PACKAGE_PREFIX_DIR is set by @PACKAGE_INIT@ to the root of the install tree.
find_library(AME_CORE_LIBRARY
    NAMES ame_core
    PATHS "${PACKAGE_PREFIX_DIR}/lib"
    NO_DEFAULT_PATH
    REQUIRED
)
find_library(LAPKT_CORE_LIBRARY
    NAMES lapkt_core
    PATHS "${PACKAGE_PREFIX_DIR}/lib"
    NO_DEFAULT_PATH
    REQUIRED
)
find_library(PCL_CORE_LIBRARY
    NAMES pcl_core
    PATHS "${PACKAGE_PREFIX_DIR}/lib"
    NO_DEFAULT_PATH
    REQUIRED
)
find_library(BTCPP_LIBRARY
    NAMES behaviortree_cpp
    PATHS "${PACKAGE_PREFIX_DIR}/lib"
    NO_DEFAULT_PATH
    REQUIRED
)
find_library(AME_FOXGLOVE_LIBRARY
    NAMES ame_foxglove
    PATHS "${PACKAGE_PREFIX_DIR}/lib"
    NO_DEFAULT_PATH
)

if(NOT TARGET ame::ame_core)
    add_library(ame::lapkt_core STATIC IMPORTED GLOBAL)
    set_target_properties(ame::lapkt_core PROPERTIES
        IMPORTED_LOCATION "${LAPKT_CORE_LIBRARY}"
    )

    add_library(ame::pcl_core STATIC IMPORTED GLOBAL)
    set_target_properties(ame::pcl_core PROPERTIES
        IMPORTED_LOCATION "${PCL_CORE_LIBRARY}"
        INTERFACE_INCLUDE_DIRECTORIES "${PACKAGE_PREFIX_DIR}/include"
    )

    add_library(ame::behaviortree_cpp STATIC IMPORTED GLOBAL)
    set_target_properties(ame::behaviortree_cpp PROPERTIES
        IMPORTED_LOCATION "${BTCPP_LIBRARY}"
        INTERFACE_INCLUDE_DIRECTORIES "${PACKAGE_PREFIX_DIR}/include"
    )

    add_library(ame::ame_core STATIC IMPORTED GLOBAL)
    set_target_properties(ame::ame_core PROPERTIES
        IMPORTED_LOCATION "${AME_CORE_LIBRARY}"
        INTERFACE_INCLUDE_DIRECTORIES "${PACKAGE_PREFIX_DIR}/include"
        INTERFACE_LINK_LIBRARIES "ame::lapkt_core;ame::pcl_core;ame::behaviortree_cpp"
    )

    if(AME_FOXGLOVE_LIBRARY)
        add_library(ame::ame_foxglove STATIC IMPORTED GLOBAL)
        set_target_properties(ame::ame_foxglove PROPERTIES
            IMPORTED_LOCATION "${AME_FOXGLOVE_LIBRARY}"
            INTERFACE_INCLUDE_DIRECTORIES "${PACKAGE_PREFIX_DIR}/include"
            INTERFACE_LINK_LIBRARIES "ame::ame_core"
        )
    endif()
endif()

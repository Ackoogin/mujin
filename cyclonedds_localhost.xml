<CycloneDDS>
  <Domain>
    <General>
      <!-- Bind to WiFi (192.168.1.69) which supports multicast on Windows.
           This keeps all DDS traffic on a single local interface.
           Update address if the machine's WiFi IP changes. -->
      <Interfaces>
        <NetworkInterface address="192.168.1.69" multicast="true"/>
      </Interfaces>
    </General>
  </Domain>
</CycloneDDS>

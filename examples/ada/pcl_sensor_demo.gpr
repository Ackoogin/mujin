project Pcl_Sensor_Demo is
  Root_Dir := "D:/Dev/repo/ame";

  for Languages use ("Ada", "C");

  for Source_Dirs use (".", "../../src/pcl");
  for Main use ("pcl_sensor_demo.adb");

  for Object_Dir use "obj";
  for Exec_Dir use "bin";

  package Compiler is
    for Default_Switches ("Ada") use ("-g");
    for Default_Switches ("C") use
      ("-std=c17",
       "-I" & Root_Dir & "/include",
       "-I" & Root_Dir & "/src/pcl");
  end Compiler;
end Pcl_Sensor_Demo;

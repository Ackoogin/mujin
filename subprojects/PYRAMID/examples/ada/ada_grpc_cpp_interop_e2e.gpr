project Ada_Grpc_Cpp_Interop_E2E is
  for Languages use ("Ada");

  for Source_Dirs use (".");
  for Main use ("ada_grpc_cpp_interop_e2e.adb");

  for Object_Dir use "obj_grpc_cpp_interop";
  for Exec_Dir use "bin";

  package Compiler is
    for Default_Switches ("Ada") use ("-g");
  end Compiler;

  package Linker is
    for Default_Switches ("Ada") use ("-lkernel32");
  end Linker;
end Ada_Grpc_Cpp_Interop_E2E;

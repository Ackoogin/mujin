# port NAME MODE PEER PLUGIN PLUGIN_CONFIG
# Request and Information remain separate generated ports. Mission Autonomy
# uses one shared-memory connection for C2 and another for Mission System.
port c2_action_command_request rpc c2 plugins/libpcl_transport_shared_memory_plugin.so {"bus_name":"agra_p3_c2_ma_link","participant_id":"mission_autonomy"}
port c2_action_information pubsub c2 plugins/libpcl_transport_shared_memory_plugin.so {"bus_name":"agra_p3_c2_ma_link","participant_id":"mission_autonomy"}
port ms_task_command_request rpc mission_system plugins/libpcl_transport_shared_memory_plugin.so {"bus_name":"agra_p3_ma_ms_link","participant_id":"mission_autonomy"}
port ms_task_information pubsub mission_system plugins/libpcl_transport_shared_memory_plugin.so {"bus_name":"agra_p3_ma_ms_link","participant_id":"mission_autonomy"}

# port NAME MODE PEER PLUGIN PLUGIN_CONFIG
# Mission Autonomy accepts C2 on port 19401 and connects to Mission System on
# port 19402. Each logical port chooses RPC or pub/sub independently.
port c2_action_command_request rpc c2 plugins/libpcl_transport_socket_plugin.so {"role":"provided","port":19401}
port c2_action_information pubsub c2 plugins/libpcl_transport_socket_plugin.so {"role":"provided","port":19401}
port ms_task_command_request rpc mission_system plugins/libpcl_transport_socket_plugin.so {"role":"consumed","host":"127.0.0.1","port":19402}
port ms_task_information pubsub mission_system plugins/libpcl_transport_socket_plugin.so {"role":"consumed","host":"127.0.0.1","port":19402}

with "gnatcoll_json.gpr";

project Ada_Active_Find_E2E is
  Root_Dir := external("UNMANNED_ROOT", ".." & "/.." & "/..");
  Pcl_Include_Dir := external("PCL_INCLUDE_DIR", Root_Dir & "/include");
  Pcl_Lib_Dir := external("PCL_LIB_DIR", Root_Dir & "/build/install/lib");
  Pcl_Lib_Name := external("PCL_LIB_NAME", "pcl_core");
  Pcl_Socket_Lib_Name := external("PCL_SOCKET_LIB_NAME", "pcl_transport_socket");
  Pyramid_Gen_Lib_Dir := external("PYRAMID_GEN_LIB_DIR", Root_Dir & "/build/ada_gnat_pyramid");
  Pyramid_Gen_Lib_Name := external("PYRAMID_GEN_LIB_NAME", "pyramid_generated_flatbuffers_codec");
  Pyramid_Codecs_Lib_Dir := external("PYRAMID_CODECS_LIB_DIR", Root_Dir & "/build/subprojects/PYRAMID");
  Pyramid_Codecs_Lib_Name := external("PYRAMID_CODECS_LIB_NAME", "pyramid_generated_codecs");
  Pyramid_Ada_Bindings_Dir :=
    external("PYRAMID_ADA_BINDINGS_DIR", Root_Dir & "/build/generated/pyramid_ada_bindings");
  Pyramid_Ada_Flatbuffers_Dir :=
    external("PYRAMID_ADA_FLATBUFFERS_DIR", Pyramid_Ada_Bindings_Dir & "/flatbuffers/ada");
  Cxx_Lib_Dir := external("CXX_LIB_DIR", "/usr/lib/gcc/x86_64-linux-gnu/11");

  for Languages use ("Ada", "C");

  for Source_Dirs use
    (".",
     Root_Dir & "/subprojects/PYRAMID/examples/ada",
     Root_Dir & "/subprojects/PCL/bindings/ada",
     Pyramid_Ada_Bindings_Dir,
     Pyramid_Ada_Flatbuffers_Dir);
  for Main use ("ada_active_find_e2e.adb");

  for Object_Dir use "obj_active_find";
  for Exec_Dir use "bin";

  package Compiler is
    for Default_Switches ("Ada") use ("-g");
    for Default_Switches ("C") use
      ("-std=c11",
       "-I" & Pcl_Include_Dir);
  end Compiler;

  type OS_Type is ("Windows_NT", "linux", "darwin");
  OS : OS_Type := external ("OS", "linux");

  package Linker is
    case OS is
      when "Windows_NT" =>
        for Default_Switches ("Ada") use
          ("-L" & Pcl_Lib_Dir,
           "-L" & Pyramid_Gen_Lib_Dir,
           "-L" & Pyramid_Codecs_Lib_Dir,
           "-L" & Cxx_Lib_Dir,
           "-l" & Pcl_Lib_Name,
           "-l" & Pyramid_Gen_Lib_Name,
           "-l" & Pyramid_Codecs_Lib_Name,
           "-lstdc++",
           "-lws2_32",
           "-lkernel32");
      when others =>
        for Default_Switches ("Ada") use
          ("-L" & Pcl_Lib_Dir,
           "-L" & Pyramid_Gen_Lib_Dir,
           "-L" & Pyramid_Codecs_Lib_Dir,
           "-L" & Cxx_Lib_Dir,
           "-l" & Pcl_Lib_Name,
           "-l" & Pyramid_Gen_Lib_Name,
           "-l" & Pyramid_Codecs_Lib_Name,
           "-lstdc++",
           "-ldl");
    end case;
  end Linker;
end Ada_Active_Find_E2E;

project Test_Ada_Cpp_Codec_Roundtrip is
  Root_Dir := external("UNMANNED_ROOT", ".." & "/.." & "/..");
  Pcl_Include_Dir := external("PCL_INCLUDE_DIR", Root_Dir & "/include");
  Pcl_Lib_Dir := external("PCL_LIB_DIR", Root_Dir & "/build/install/lib");
  Pcl_Lib_Name := external("PCL_LIB_NAME", "pcl_core");
  -- Ada depends on PCL + the C-ABI marshal layer only -- never on
  -- codec-specific (wire codec) content.
  Pyramid_Cabi_Lib_Dir :=
    external("PYRAMID_CABI_LIB_DIR", Root_Dir & "/build/ada_gnat_pyramid_cabi");
  Pyramid_Cabi_Lib_Name :=
    external("PYRAMID_CABI_LIB_NAME", "pyramid_generated_cabi_marshal");
  Pyramid_Ada_Bindings_Dir :=
    external("PYRAMID_ADA_BINDINGS_DIR", Root_Dir & "/build/generated/pyramid_ada_bindings");
  Cxx_Lib_Dir := external("CXX_LIB_DIR", "/usr/lib/gcc/x86_64-linux-gnu/11");

  for Languages use ("Ada");
  for Source_Dirs use
    (".",
     Root_Dir & "/subprojects/PCL/bindings/ada",
     Pyramid_Ada_Bindings_Dir);
  for Main use ("test_ada_cpp_codec_roundtrip.adb");

  for Object_Dir use "obj_ada_cpp_codec_roundtrip";
  for Exec_Dir use "bin";

  package Compiler is
    for Default_Switches ("Ada") use ("-g");
    for Default_Switches ("C") use
      ("-std=c11",
       "-I" & Pcl_Include_Dir);
  end Compiler;

  type OS_Type is ("Windows_NT", "linux", "darwin");
  OS : OS_Type := external ("OS", "linux");

  package Linker is
    case OS is
      when "Windows_NT" =>
        for Default_Switches ("Ada") use
          ("-L" & Pcl_Lib_Dir,
           "-L" & Pyramid_Cabi_Lib_Dir,
           "-L" & Cxx_Lib_Dir,
           "-l" & Pcl_Lib_Name,
           "-l" & Pyramid_Cabi_Lib_Name,
           "-lstdc++",
           "-lws2_32",
           "-lkernel32");
      when others =>
        for Default_Switches ("Ada") use
          ("-L" & Pcl_Lib_Dir,
           "-L" & Pyramid_Cabi_Lib_Dir,
           "-L" & Cxx_Lib_Dir,
           "-l" & Pcl_Lib_Name,
           "-l" & Pyramid_Cabi_Lib_Name,
           "-lstdc++",
           "-ldl");
    end case;
  end Linker;
end Test_Ada_Cpp_Codec_Roundtrip;

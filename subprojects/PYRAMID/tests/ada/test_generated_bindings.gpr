--  GPR project for the generated-bindings compilation + round-trip test.
--  Tests that all generated Ada packages (types, codecs, service bindings)
--  compile and that basic codec round-trips work correctly.
--
--  Build:  gprbuild -p -P test_generated_bindings.gpr
--  Run:    bin/test_generated_bindings

with "gnatcoll";

project Test_Generated_Bindings is
  Root_Dir := external("MUJIN_ROOT", ".." & "/.." & "/..");
  Pcl_Include_Dir := external("PCL_INCLUDE_DIR", Root_Dir & "/include");
  Pcl_Lib_Dir := external("PCL_LIB_DIR", Root_Dir & "/build/install/lib");
  Pcl_Lib_Name := external("PCL_LIB_NAME", "pcl_core");
  Pcl_Socket_Lib_Name := external("PCL_SOCKET_LIB_NAME", "pcl_transport_socket");
  Pyramid_Gen_Lib_Dir := external("PYRAMID_GEN_LIB_DIR", Root_Dir & "/build/ada_gnat_pyramid");
  Pyramid_Gen_Lib_Name := external("PYRAMID_GEN_LIB_NAME", "pyramid_generated_flatbuffers_codec");

  for Languages use ("Ada");

  for Source_Dirs use
    (".",
     Root_Dir & "/subprojects/PYRAMID/examples/ada",
     Root_Dir & "/subprojects/PYRAMID/bindings/ada/generated",
     Root_Dir & "/subprojects/PYRAMID/bindings/ada/generated/flatbuffers/ada",
     Root_Dir & "/subprojects/PYRAMID/bindings/ada/generated/protobuf/ada",
     Root_Dir & "/subprojects/PYRAMID/bindings/ada/generated/grpc/ada");
  for Main use ("test_generated_bindings.adb");

  for Object_Dir use "obj_test_bindings";
  for Exec_Dir use "bin";

  package Compiler is
    for Default_Switches ("Ada") use ("-g");
    for Default_Switches ("C") use
      ("-std=c11",
       "-I" & Pcl_Include_Dir);
  end Compiler;

  type OS_Type is ("Windows_NT", "linux", "darwin");
  OS : OS_Type := external ("OS", "linux");

  package Linker is
    case OS is
      when "Windows_NT" =>
        for Default_Switches ("Ada") use
          ("-L" & Pcl_Lib_Dir,
           "-L" & Pyramid_Gen_Lib_Dir,
           "-l" & Pcl_Lib_Name,
           "-l" & Pcl_Socket_Lib_Name,
           "-l" & Pyramid_Gen_Lib_Name,
           "-lstdc++",
           "-lws2_32");
      when others =>
        for Default_Switches ("Ada") use
          ("-L" & Pcl_Lib_Dir,
           "-L" & Pyramid_Gen_Lib_Dir,
           "-l" & Pcl_Lib_Name,
           "-l" & Pcl_Socket_Lib_Name,
           "-l" & Pyramid_Gen_Lib_Name,
           "-lstdc++");
    end case;
  end Linker;
end Test_Generated_Bindings;
